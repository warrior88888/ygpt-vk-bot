# ── VK ────────────────────────────────────────────────────────────────────────
BOT__VK__API_KEY=your_vk_community_api_token

# ── Yandex GPT ────────────────────────────────────────────────────────────────
BOT__YANDEX__API_KEY=your_yandex_api_key
BOT__YANDEX__FOLDER_ID=your_yandex_folder_id
BOT__YANDEX__MODEL_URI=gpt://your_folder_id/yandexgpt/latest
BOT__YANDEX__TEMPERATURE=0.7
BOT__YANDEX__MAX_TOKENS=1000

# ── Redis ─────────────────────────────────────────────────────────────────────
BOT__REDIS__PASSWORD=your_redis_password
BOT__REDIS__PORT=6379
# BOT__REDIS__HOST is set automatically to "redis" inside Docker

# ── Logging (optional) ────────────────────────────────────────────────────────
BOT__LOG__LEVEL=INFO

# ── Conversation context (optional) ───────────────────────────────────────────
# BOT__CONTEXT__MAX_MESSAGES=3   # number of last message pairs to keep
# BOT__CONTEXT__TTL=3600         # context lifetime in seconds

# ── Rate limits (optional) ────────────────────────────────────────────────────
# BOT__RATE_LIMITS__LIMIT=100          # max messages per window
# BOT__RATE_LIMITS__WINDOW=60          # window size in seconds
# BOT__RATE_LIMITS__PROCESSING_TTL=20  # max seconds a request can be "in progress"
